                {
                  "type": "text",
                  "id": "Nnpka",
                  "name": "r4c",
                  "fill": "#71717A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "# cloud_services.py\n@http.route('/api/cloud-services/\n  <int:workspace_id>/services',\n  type='json', auth='user',\n  methods=['POST'])\ndef deploy_service(self, workspace_id,\n  **kwargs):\n\n  template = request.env[\n    'woow_paas_platform.cloud_app_template'\n  ].browse(template_id)\n\n  service = request.env[\n    'woow_paas_platform.cloud_service'\n  ].create({\n    'name': service_name,\n    'workspace_id': workspace_id,\n    'template_id': template.id,\n    'state': 'deploying',\n  })\n\n  # 背景 Thread 執行部署\n  thread = threading.Thread(\n    target=service._deploy_async\n  )\n  thread.start()",
                  "lineHeight": 1.5,
                  "fontFamily": "Roboto Mono",
                  "fontSize": 13
                }
              ]
            }
          ]
        }
